{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "commonjs",
    "moduleResolution":  "node",
    "esModuleInterop":   true,
    "strict":            true,
    "resolveJsonModule": true,
    "outDir":            "dist",
    "rootDir":           ".",
    "skipLibCheck":      true
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
